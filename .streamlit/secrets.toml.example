# Azure AD / Microsoft Entra ID configuration
# Copy this file to secrets.toml and fill in your values.
# On Streamlit Cloud, add these in Settings > Secrets.
#
# If these values are not set, the app falls back to manual email input.

[azure]
client_id = "YOUR_APPLICATION_CLIENT_ID"
client_secret = "YOUR_CLIENT_SECRET"
tenant_id = "YOUR_EY_TENANT_ID"
redirect_uri = "https://factory-dashboard-demo-ey.streamlit.app"
